# ==========================================================================
#  PLANTILLA de variables de entorno — Connectivity (temporerosweb)
#  Copia este archivo como ".env" y rellena los valores REALES.
#  NUNCA pongas valores reales aquí: este archivo SÍ se sube a git.
#  El ".env" real está en .gitignore y NO se sube.
#
#  En Vercel: añade estas mismas variables en
#  Project → Settings → Environment Variables (Production).
# ==========================================================================


# === 1) Stripe (pasarela de pago) ============================ [OBLIGATORIA]
# Clave secreta de Stripe.
#   · Pruebas:    sk_test_...
#   · Producción: sk_live_...
STRIPE_SECRET_KEY=


# === 2) Google Sheets (registro de pedidos vía Apps Script) == [OBLIGATORIA]
# URL "/exec" de la implementación del Apps Script (google-apps-script.gs).
SHEETS_WEBHOOK_URL=
# Debe coincidir EXACTAMENTE con SECRET_TOKEN dentro de google-apps-script.gs.
SHEETS_WEBHOOK_SECRET=


# === 3) Didit (verificación de identidad / KYC) ============== [OBLIGATORIA]
# API key secreta de tu Application en Didit (cabecera x-api-key).
DIDIT_API_KEY=
# ID del workflow de verificación (KYC) configurado en el panel de Didit.
DIDIT_KYC_WORKFLOW_ID=


# === 4) URL pública de la app =============== [OBLIGATORIA EN PRODUCCIÓN]
# A dónde vuelven Stripe y Didit tras pagar/verificar.
# Sin esto redirige a http://localhost:8080 (falla en producción).
#   · Local:      http://localhost:8080  (valor por defecto, puedes omitirla)
#   · Producción: https://temporerosweb.vercel.app   (o tu dominio propio)
APP_BASE_URL=


# ==========================================================================
#  OPCIONALES / RESERVADAS (no hacen falta para el flujo actual)
# ==========================================================================

# Base de la API de Didit (por defecto https://verification.didit.me).
# DIDIT_BASE_URL=https://verification.didit.me

# Workflow biométrico de Didit — reservado para el futuro, hoy NO se usa.
# DIDIT_BIOMETRIC_AUTH_WORKFLOW_ID=

# Excel local — SOLO alternativa si NO usas Google Sheets (no aplica en Vercel).
# EXCEL_PATH=C:\Users\janol\Downloads\Orderflow temporeros.xlsx

# API de Orange (activación de SIM) — PENDIENTE de la doc de Orange.
# ORANGE_API_BASE=
# ORANGE_API_KEY=
