# === Destino de los datos: Google Sheets (en vivo) ===
# Si defines SHEETS_WEBHOOK_URL, la web escribe en el Google Sheet a través del
# webhook de Apps Script (ver google-apps-script.gs). Si lo dejas vacío, escribe
# en el Excel local (EXCEL_PATH) como alternativa.
SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/AKfycbz6TPGbvr2caOaVDgWnx16tme9CFa0EfDjUJ5HCOOlbfG35nUho-jWMkh91dsQhqvgs/exec
# El mismo SECRET_TOKEN definido en google-apps-script.gs
SHEETS_WEBHOOK_SECRET=


# === Verificación de identidad con Didit (hoja "Validacion Didit") ===
# API key secreta de tu Application en Didit (cabecera x-api-key). NO la compartas.
DIDIT_API_KEY=lJLaCLzuN5PguiTGs4BxiKgiVV-1peR98f4cZr0G9i0
# ID del workflow de verificación configurado en el panel de Didit.
DIDIT_KYC_WORKFLOW_ID=4458092d-d3aa-4ded-b029-d43f8012e6a7
DIDIT_BIOMETRIC_AUTH_WORKFLOW_ID=3b13da12-bb95-42c1-a0a0-350c0f73e171
# Opcional: base de la API de Didit (por defecto https://verification.didit.me)
# DIDIT_BASE_URL=https://verification.didit.me
# Opcional: URL base de esta app, a donde Didit/Stripe devuelven al cliente (por defecto http://localhost:8080)
# APP_BASE_URL=http://localhost:8080


# === Stripe (suscripción mensual) ===
# Clave secreta: sk_test_... en pruebas, sk_live_... en producción.
STRIPE_SECRET_KEY=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
