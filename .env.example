```env
# === Destino de datos: Google Sheets ===
# Si SHEETS_WEBHOOK_URL está definido, la aplicación escribe en Google Sheets
# mediante el webhook de Apps Script.
# Si se deja vacío, puede utilizar EXCEL_PATH como alternativa local.

SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/REEMPLAZAR_CON_NUEVA_URL/exec

# Debe coincidir con SECRET_TOKEN en google-apps-script.gs.
# No puede quedar vacío si el Apps Script valida el token.
SHEETS_WEBHOOK_SECRET=REEMPLAZAR_CON_UN_SECRETO_SEGURO


# === Alternativa: Excel local ===
# Solo se utiliza si SHEETS_WEBHOOK_URL está vacío.
# En Windows, es preferible usar barras normales o duplicar las barras invertidas.

# EXCEL_PATH=C:/Users/janol/Downloads/Orderflow temporeros.xlsx


# === Verificación de identidad con Didit ===
# Clave secreta enviada en la cabecera x-api-key.
DIDIT_API_KEY=REEMPLAZAR_CON_NUEVA_API_KEY

# Workflows configurados en Didit.
DIDIT_KYC_WORKFLOW_ID=4458092d-d3aa-4ded-b029-d43f8012e6a7
DIDIT_BIOMETRIC_AUTH_WORKFLOW_ID=3b13da12-bb95-42c1-a0a0-350c0f73e171

# Opcional. Se usa este valor por defecto si la variable no está definida.
# DIDIT_BASE_URL=https://verification.didit.me


# === URL pública de la aplicación ===
# Debe ser la URL real en producción para los retornos de Didit y Stripe.
# En desarrollo local puede ser:
APP_BASE_URL=http://localhost:8080

# Ejemplo de producción:
# APP_BASE_URL=https://tudominio.com


# === Stripe: suscripción mensual ===
# Usa sk_test_ con precios de prueba y sk_live_ con precios de producción.
STRIPE_SECRET_KEY=REEMPLAZAR_CON_NUEVA_CLAVE_STRIPE

STRIPE_PRICE_P80=price_1TquLWI4pPEu9sUgX2Ufovvu
STRIPE_PRICE_P150=price_1TrBc5I4pPEu9sUgcyxEEwud

# Añádelo si la aplicación recibe webhooks de Stripe.
# Es diferente de STRIPE_SECRET_KEY.
# STRIPE_WEBHOOK_SECRET=whsec_REEMPLAZAR


# === API de Orange ===
# Pendiente de recibir endpoints y credenciales de Orange.
ORANGE_API_BASE=
ORANGE_API_KEY=
```
